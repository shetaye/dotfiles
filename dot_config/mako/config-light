# Global Style Options
font=BerkeleyMono Nerd Font Mono 10
background-color=#c9b9b0
text-color=#000000
width=350
height=150
margin=20
padding=15
border-size=2
border-color=#9f9690
border-radius=0
progress-color=over #595959
icons=1
max-icon-size=48
markup=1
format=<b>%s</b>\n%b

# Low Urgency
[urgency=low]
border-color=#efe9dd
text-color=#595959

# Critical Urgency
[urgency=critical]
background-color=#c9b9b0
border-color=#d00000
border-size=3
default-timeout=0
