# Global Style Options
font=BerkeleyMono Nerd Font Mono 10
background-color=#2a2b42
text-color=#ffffff
width=350
height=150
margin=20
padding=15
border-size=2
border-color=#61647a
border-radius=0
progress-color=over #989898
icons=1
max-icon-size=48
markup=1
format=<b>%s</b>\n%b

# Low Urgency
[urgency=low]
border-color=#1d2235
text-color=#989898

# Critical Urgency
[urgency=critical]
background-color=#2a2b42
border-color=#ff5f59
border-size=3
default-timeout=0
