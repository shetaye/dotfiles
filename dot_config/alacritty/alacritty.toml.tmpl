[font]
{{- if eq .chezmoi.hostname "enkidu" }}
size = 13.5
{{- else }}
size = 9
{{- end }}

[font.normal]
family = "IosevkaTerm Nerd Font Mono"
style  = "Regular"

[font.bold]
family = "IosevkaTerm Nerd Font Mono"
style  = "Bold"

[font.italic]
family = "IosevkaTerm Nerd Font Mono"
style  = "Italic"

[font.bold_italic]
family = "IosevkaTerm Nerd Font Mono"
style  = "Bold Italic"


#[font]
#size = 13
#[font.normal]
#family = "Cozette"
#style = "Medium"

#[font]
#size = 10
#[font.normal]
#family = "BerkeleyMono Nerd Font Mono"
#style = "Regular"



[font.offset]
x = 0
y = 0

[window]

opacity=1

[general]
import = ["~/.config/alacritty/current-theme.toml"]

[[keyboard.bindings]]
key = "Return"
mods = "Shift"
chars = "\u001B\r"
