set $mod Mod4

font pango:Terminess Nerd Font Mono 13, monospace 8

exec --no-startup-id dex --autostart --environment i3
exec --no-startup-id ~/.local/bin/x11-display-setup
exec --no-startup-id sh -c 'sleep 2; exec darkman run'
exec --no-startup-id xss-lock --transfer-sleep-lock -- i3lock --nofork
exec --no-startup-id nm-applet
exec --no-startup-id emacs --daemon
exec --no-startup-id picom --config ~/.config/picom/picom.conf
exec --no-startup-id dunst

bindsym $mod+backslash exec emacsclient -c -a "" "$HOME/org/motd.org"

bindsym XF86AudioRaiseVolume exec --no-startup-id pactl set-sink-volume @DEFAULT_SINK@ +10%
bindsym XF86AudioLowerVolume exec --no-startup-id pactl set-sink-volume @DEFAULT_SINK@ -10%
bindsym XF86AudioMute exec --no-startup-id pactl set-sink-mute @DEFAULT_SINK@ toggle
bindsym XF86AudioMicMute exec --no-startup-id pactl set-source-mute @DEFAULT_SOURCE@ toggle

floating_modifier $mod

# i3 supports this; Sway keeps it disabled.
# tiling_drag modifier titlebar

bindsym $mod+Return exec alacritty
bindsym Control+Mod1+Return exec alacritty
bindsym Control+Mod1+Escape exec i3-msg exit
bindsym $mod+Shift+q kill
bindsym $mod+d exec --no-startup-id rofi -show drun
bindsym $mod+o exec --no-startup-id ~/.local/bin/passmenu-x11

bindsym $mod+j focus left
bindsym $mod+k focus down
bindsym $mod+l focus up
bindsym $mod+semicolon focus right

bindsym $mod+Left focus left
bindsym $mod+Down focus down
bindsym $mod+Up focus up
bindsym $mod+Right focus right

bindsym $mod+Shift+j move left
bindsym $mod+Shift+k move down
bindsym $mod+Shift+l move up
bindsym $mod+Shift+semicolon move right

bindsym $mod+Shift+Left move left
bindsym $mod+Shift+Down move down
bindsym $mod+Shift+Up move up
bindsym $mod+Shift+Right move right

bindsym $mod+h split h
bindsym $mod+v split v
bindsym $mod+f fullscreen toggle

bindsym $mod+s layout stacking
# bindsym $mod+w layout tabbed
bindsym $mod+e layout toggle split

bindsym $mod+Shift+space floating toggle
bindsym $mod+space focus mode_toggle
bindsym $mod+a focus parent
#bindsym $mod+d focus child

set $ws1 "1"
set $ws2 "2"
set $ws3 "3"
set $ws4 "4"
set $ws5 "5"
set $ws6 "6"
set $ws7 "7"
set $ws8 "8"
set $ws9 "9"
set $ws10 "10"

bindsym $mod+1 workspace number $ws1
bindsym $mod+2 workspace number $ws2
bindsym $mod+3 workspace number $ws3
bindsym $mod+4 workspace number $ws4
bindsym $mod+5 workspace number $ws5
bindsym $mod+6 workspace number $ws6
bindsym $mod+7 workspace number $ws7
bindsym $mod+8 workspace number $ws8
bindsym $mod+9 workspace number $ws9
bindsym $mod+0 workspace number $ws10

bindsym $mod+Shift+1 move container to workspace number $ws1
bindsym $mod+Shift+2 move container to workspace number $ws2
bindsym $mod+Shift+3 move container to workspace number $ws3
bindsym $mod+Shift+4 move container to workspace number $ws4
bindsym $mod+Shift+5 move container to workspace number $ws5
bindsym $mod+Shift+6 move container to workspace number $ws6
bindsym $mod+Shift+7 move container to workspace number $ws7
bindsym $mod+Shift+8 move container to workspace number $ws8
bindsym $mod+Shift+9 move container to workspace number $ws9
bindsym $mod+Shift+0 move container to workspace number $ws10

bindsym $mod+Shift+c reload
bindsym $mod+Shift+r restart
bindsym $mod+Shift+e exec "i3-nagbar -f 'pango:Terminess Nerd Font Mono 10' -t warning -m 'Exit?' -B 'Yes, exit i3' 'i3-msg exit'"
bindsym $mod+Shift+t exec --no-startup-id darkman toggle

mode "resize" {
        bindsym j resize shrink width 10 px or 10 ppt
        bindsym k resize grow height 10 px or 10 ppt
        bindsym l resize shrink height 10 px or 10 ppt
        bindsym semicolon resize grow width 10 px or 10 ppt

        bindsym Left resize shrink width 10 px or 10 ppt
        bindsym Down resize grow height 10 px or 10 ppt
        bindsym Up resize shrink height 10 px or 10 ppt
        bindsym Right resize grow width 10 px or 10 ppt

        bindsym Return mode "default"
        bindsym Escape mode "default"
        bindsym $mod+r mode "default"
}

bindsym $mod+r mode "resize"

mode "window" {
    bindsym h move workspace to output left
    bindsym j move workspace to output down
    bindsym k move workspace to output up
    bindsym l move workspace to output right
    bindsym Return mode "default"
    bindsym Escape mode "default"
    bindsym $mod+w mode "default"
}
bindsym $mod+w mode "window"

bindsym $mod+Control+l exec "i3lock -i ~/.config/wallpaper.png"
bindsym $mod+p exec screenshot-x11
bindsym XF86MonBrightnessDown exec brightnessctl set 10%-
bindsym XF86MonBrightnessUp exec brightnessctl set 10%+

exec_always --no-startup-id ~/.config/polybar/startup.sh

default_border pixel 2

gaps inner 10
gaps outer 10
smart_gaps inverse_outer

set $bg #030102
set $red #ff7358
set $green #ffd8ff
set $yellow #8380b9
set $blue #8380b9
set $purple #ffd8ff
set $aqua #ff7358
set $gray #473E42
set $darkgray #1F181B
set $white #FFD8FF

client.focused          $red   $blue   $darkgray $blue   $red
client.focused_inactive $darkgray $darkgray $blue   $blue   $darkgray
client.unfocused        $darkgray $darkgray $blue   $blue   $darkgray
client.urgent           $red      $red      $white    $red      $red

set $ws_discord "Discord"
set $ws_betterbird "Betterbird"
set $ws_1password "Passwords"
set $ws_signal "Signal"

assign [class="(?i)discord"] workspace $ws_discord
assign [class="(?i)betterbird"] workspace $ws_betterbird
assign [class="(?i)1password"] workspace $ws_1password
assign [class="(?i)signal"] workspace $ws_signal

bindsym F9                      workspace $ws_discord;    exec pgrep -x Discord || discord
bindsym Print                   workspace $ws_discord;    exec pgrep -x Discord || discord
bindsym F10                     workspace $ws_betterbird; exec pgrep -x betterbird || betterbird
bindsym XF86SelectiveScreenshot workspace $ws_betterbird; exec pgrep -x betterbird || betterbird
bindsym XF86PickupPhone         workspace $ws_betterbird; exec pgrep -x betterbird || betterbird
bindsym F11                     workspace $ws_1password;  exec pgrep -x 1password || 1password
bindsym XF86LinkPhone           workspace $ws_1password;  exec pgrep -x 1password || 1password
bindsym XF86HangupPhone         workspace $ws_1password;  exec pgrep -x 1password || 1password
bindsym F12                     workspace $ws_signal;     exec pgrep -x signal-desktop || signal-desktop
bindsym XF86Favorites           workspace $ws_signal;     exec pgrep -x signal-desktop || signal-desktop

bindsym $mod+g gaps horizontal current set 1280
bindsym $mod+Shift+g gaps horizontal current set 0
